# FM21 production environment template (U30)
# Copy to repo-root .env for local pet-project deploy. NEVER commit .env.
#
# Usage:
#   cp deploy/production/env.template .env
#   # edit secrets below
#   docker compose -f deploy/production/docker-compose.prod.yml up -d --build
#
# Local pet project defaults to BOT_MODE=polling (no public HTTPS / ngrok required).
# For Telegram webhook mode later: set BOT_MODE=webhook, TELEGRAM_WEBHOOK_URL=https://…,
# then run scripts/set_telegram_webhook.sh (Telegram requires HTTPS).

# --- PostgreSQL ---
POSTGRES_USER=fm21
POSTGRES_PASSWORD=change-me-prod
POSTGRES_DB=fm21
DATABASE_URL=postgresql://fm21:change-me-prod@postgres:5432/fm21

# --- Redis (internal Docker network) ---
REDIS_URL=redis://redis:6379/0

# --- Broadcast ---
ICECAST_SOURCE_PASSWORD=change-me-icecast
INTERNAL_ENQUEUE_TOKEN=change-me-internal
MAX_PENDING_ADS_PER_CITY=5
MAX_AD_DURATION_SEC=60

# --- Geo ---
DEFAULT_CITY_TAG=moscow
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb
TRUSTED_PROXY_IPS=127.0.0.1,::1

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-webhook-secret
# polling = local pet project (default). webhook = production with public HTTPS endpoint.
BOT_MODE=polling
# Optional — required only for BOT_MODE=webhook. Must be HTTPS (no path suffix).
# TELEGRAM_WEBHOOK_URL=https://your-domain.example.com
DEFAULT_OPERATOR_CITY=moscow
TELEGRAM_OPERATOR_IDS=
TELEGRAM_ADMIN_IDS=
# Never enable in production; local pet project may use 0 with polling.
BOT_OPEN_ACCESS=0
LISTENER_BASE_URL=http://127.0.0.1:8080

# --- Music ---
MUSIC_PROVIDER=static
# YANDEX_MUSIC_OAUTH_TOKEN=
MUSIC_BUFFER_TARGET=10
MUSIC_BUFFER_POLL_INTERVAL_SEC=15

# --- News (optional — leave empty to skip live API calls) ---
# GIGACHAT_CREDENTIALS=
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# SALUTESPEECH_CREDENTIALS=
# SALUTESPEECH_SCOPE=SALUTE_SPEECH_PERS
# SALUTESPEECH_VOICE=Nec_24000
# SALUTESPEECH_VERIFY_SSL_CERTS=true

# --- Gateway image pin (optional) ---
# NGINX_IMAGE=nginx:1.27-alpine
