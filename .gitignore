.compound-engineering/*.local.yaml

# Secrets and local env
.env

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Runtime-generated ads (voice transcodes)
data/ads/*

# Runtime-generated news audio (TTS output + Redis-backed cache by content hash)
data/news/cache/
data/news/*.mp3
!data/news/news-stinger.mp3

# Corporate trust anchors (local only — org policy; never commit)
certs/ca-certificates-21/

# Node (agent-browser e2e)
node_modules/
