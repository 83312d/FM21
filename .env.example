# FM21 — copy to .env (never commit .env)

# --- Broadcast ---
ICECAST_HOST=icecast
ICECAST_PORT=8000
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql://fm21:fm21dev@postgres:5432/fm21

# --- Geo (services/geo) ---
DEFAULT_CITY_TAG=moscow
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# --- Telegram bot (services/bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Local dev (no ngrok): BOT_MODE=polling — bot pulls updates from Telegram API.
BOT_MODE=polling
# macOS + ClashX: Telegram API from Docker (Clash HTTP port, usually 7890)
# TELEGRAM_PROXY_URL=http://host.docker.internal:7890
# Production / staging webhook (BOT_MODE=webhook): public HTTPS base URL, no path suffix.
# TELEGRAM_WEBHOOK_URL=https://fm21.example.com
DEFAULT_OPERATOR_CITY=moscow
# Comma-separated Telegram user IDs (production). Required unless BOT_OPEN_ACCESS=1 (dev only).
# TELEGRAM_OPERATOR_IDS=
# TELEGRAM_ADMIN_IDS=
# Dev-only: allow any Telegram user + optional webhook without secret (never in production).
# BOT_OPEN_ACCESS=1
# Gateway player URL shown to operators after voice ad enqueue (listener-facing, not Icecast).
LISTENER_BASE_URL=http://localhost:8080

# --- Ads service (services/ads, U24+) ---
ADS_URL=http://ads:8080

# --- Injector (services/injector) ---
INTERNAL_ENQUEUE_TOKEN=
# Max pending voice ads per city (R9)
MAX_PENDING_ADS_PER_CITY=5
MAX_AD_DURATION_SEC=60

# --- Metadata (services/metadata) ---
NOW_PLAYING_POLL_INTERVAL_SEC=5

# --- Music (services/music, U10+) ---
MUSIC_PROVIDER=static
STATIC_MUSIC_DIR=/data/music/static
# YANDEX_MUSIC_OAUTH_TOKEN=
MUSIC_BUFFER_TARGET=10
MUSIC_BUFFER_POLL_INTERVAL_SEC=15

# --- News (Phase 3, U15+) ---
# Russian CA bundle (MinDigital) — mount ./certs in compose (FM21_CERTS_DIR=/certs)
# Corporate CA: certs/ca-certificates-21/ (included automatically)
# FM21_CERTS_DIR=/certs
# GigaChat summarizer (U17)
# GIGACHAT_CREDENTIALS=
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# SaluteSpeech TTS (U18) — https://developers.sber.ru/docs/ru/salutespeech/overview
# SALUTESPEECH_CREDENTIALS=
# SALUTESPEECH_SCOPE=SALUTE_SPEECH_PERS
# SALUTESPEECH_VOICE=Nec_24000
# SALUTESPEECH_VERIFY_SSL_CERTS=true
